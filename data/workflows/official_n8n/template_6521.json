      "position": [
        -64,
        272
      ],
      "parameters": {
        "color": 4,
        "width": 352,
        "height": 192,
        "content": "рџљЂ MONITORING TRIGGER\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nвЂў Checks every hour for new rows\nвЂў Only processes newly added entries\nвЂў Automatically handles multiple entries\nвЂў Uses efficient polling to avoid rate limits\nвЂў Connects to your Google Sheets document\n"
